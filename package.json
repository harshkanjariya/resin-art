{
  "name": "resin-art",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:gh": "VITE_BASE_PATH=/resin-art/ tsc -b && VITE_BASE_PATH=/resin-art/ vite build",
    "preview": "vite preview",
    "preview:gh": "VITE_BASE_PATH=/resin-art/ vite preview",
    "deploy": "npm run build:gh && npx gh-pages -d dist"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "antd": "^5.22.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-alpha.34",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "gh-pages": "^6.1.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
